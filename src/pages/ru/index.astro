        <li><a href="#features" class="nav-mobile-link">АНАЛИЗ</a></li>
        <li><a href="#traumsymbole" class="nav-mobile-link">ЛЕКСИКОН</a></li>
        <li><a href="#vision" class="nav-mobile-link">VISION</a></li>
