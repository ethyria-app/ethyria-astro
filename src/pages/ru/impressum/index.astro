---
import BaseLayout from '@/layouts/BaseLayout.astro';
const _body = `
    <div class="bg-blob top-[-10%] left-[-10%]"></div>
    <nav class="container mx-auto px-6 py-6 flex justify-center items-center relative z-10">
      <a href="index.html" class="nav-brand">
        <img src="/assets/Logo_web.png" alt="Ethyria" width="240" height="57" class="nav-brand-logo" style="max-width:240px" decoding="async" />
      </a>
    </nav>
    <main class="container mx-auto px-6 py-12 relative z-10 max-w-3xl">
      <!-- 7-Grid: Pillar-Prosa-Kolumne vollbreit (col-7) -->
      <div>
      <h1 class="text-4xl font-bold mb-10 ethyria-gradient-text">Правовая информация</h1>

      <section class="mb-10">
        <h2 class="text-xl font-bold mb-3 text-white">Сведения согласно § 5 ECG (Австрийский закон об электронной коммерции)</h2>
        <div class="text-gray-300 leading-relaxed space-y-1">
          <p><strong class="text-white">Oliver Stolz</strong></p>
          <p>Ethyria Dream Analysis</p>
          <p>Freistädter Str. 65</p>
          <p>4040 Linz, Австрия</p>
        </div>
      </section>

      <section class="mb-10">
        <h2 class="text-xl font-bold mb-3 text-white">Контакт</h2>
        <div class="text-gray-300 leading-relaxed space-y-1">
          <p>Эл. почта: <!--email_off--><a href="mailto:support@ethyria.at" data-copy-email="support@ethyria.at" class="text-cyan-400 hover:underline">support@ethyria.at</a><!--/email_off--></p>
          <p>Сайт: <a href="https://ethyria.at" class="text-cyan-400 hover:underline">https://ethyria.at</a></p>
        </div>
      </section>

      <section class="mb-10">
        <h2 class="text-xl font-bold mb-3 text-white">Предмет деятельности</h2>
        <p class="text-gray-300 leading-relaxed">Разработка и эксплуатация приложения Ethyria приложения для толкования снов и ведения дневника снов для Android.</p>
      </section>

      <section class="mb-10">
        <h2 class="text-xl font-bold mb-3 text-white">Правовые уведомления</h2>
        <p class="text-gray-300 leading-relaxed mb-3">Содержимое этого сайта подготовлено с максимальной тщательностью. Мы не несём ответственности за точность, полноту или актуальность содержимого.</p>
        <p class="text-gray-300 leading-relaxed mb-3"><strong class="text-white">Отказ от ответственности Толкование снов:</strong> Толкования и анализы снов, предоставляемые Ethyria, предназначены исключительно для саморефлексии и развлечения. Они не заменяют профессиональную психологическую или терапевтическую консультацию.</p>
        <p class="text-gray-300 leading-relaxed"><strong class="text-white">Авторское право:</strong> Содержимое и произведения, созданные оператором сайта на этих страницах, защищены австрийским законодательством об авторских правах. Воспроизведение, редактирование, распространение и любое использование за пределами авторского права требуют письменного согласия соответствующего автора.</p>
      </section>

      <section class="mb-10">
        <h2 class="text-xl font-bold mb-3 text-white">Онлайн-урегулирование споров</h2>
        <p class="text-gray-300 leading-relaxed">Европейская комиссия предоставляет платформу для онлайн-урегулирования споров (ОУС): <a href="https://ec.europa.eu/consumers/odr" class="text-cyan-400 hover:underline" target="_blank" rel="noopener">https://ec.europa.eu/consumers/odr</a></p>
      </section>

      <div class="border-t border-white/10 pt-8 mt-8">
        <a href="ru/" class="text-cyan-400 hover:underline text-sm">← На главную</a>
        <span class="mx-4 text-white/20">|</span>
        <a href="datenschutz.ru.html" class="text-cyan-400 hover:underline text-sm">Политика конфиденциальности</a>
      </div>
          </div><!-- /grid-7 -->
    </main>
    <footer class="border-t border-white/5 py-8 text-center mt-16">
      <div class="container mx-auto px-6">
        <p class="text-gray-600 text-xs">© Ethyria</p>
      </div>
    </footer>
    
  `;
---

<BaseLayout
  lang="ru"
  title="Правовая информация | Ethyria"
  description=""
  keywords=""
  path="/impressum/"
>
  <Fragment set:html={_body} />
</BaseLayout>
