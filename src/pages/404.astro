---
import BaseLayout from '@/layouts/BaseLayout.astro';
const _body = `
    <div class="card">
      <span class="icon" aria-hidden="true">🌙</span>
      <h1>Diese Seite ist nur ein Traum</h1>
      <p>
        Die gesuchte Seite existiert nicht (oder nicht mehr). Kehre zur Startseite
        zurück oder folge einem der Pfade unten.
      </p>
      <a class="btn" href="/">Zur Startseite</a>
      <nav class="links" aria-label="Hilfreiche Links">
        <a href="/traumdeutung-methoden/">Traumdeutung-Methoden</a>
        <a href="/traumsymbole-guide/">Traumsymbole-Guide</a>
        <a href="/luzides-traeumen/">Luzides Träumen</a>
        <a href="/symbols/">Traumsymbol-Lexikon</a>
      </nav>
    </div>
  `;
---

<BaseLayout
  lang="de"
  title="404 Seite nicht gefunden | Ethyria"
  description=""
  keywords=""
  path="/404/"
>
  <Fragment set:html={_body} />
</BaseLayout>
