---
import BaseLayout from '@/layouts/BaseLayout.astro';
const _body = `<div id="hero" class="anchor-top" aria-hidden="true"></div>
    <a href="#main-content" class="skip-link">Aller au contenu principal</a>

    <div class="bg-blob top-[-10%] left-[-10%]"></div>
    <div class="bg-blob bottom-[20%] right-[-5%]"></div>

    <!-- ============================================================
         SITE HEADER (sticky)
         ============================================================ -->
    <header role="banner" id="site-header" class="site-header">

    <!-- LANGUAGE BAR -->
    <div
      id="top"
      class="w-full flex justify-center px-6 pt-0 pb-1 relative z-20"
    >
      <nav class="language-switcher" aria-label="Sélection de la langue">
        <a href="/" title="Deutsch"
          ><img
            src="/assets/german.png"
            alt="Deutsch"
            width="20"
            height="20"
            class="language-flag" decoding="async"
        /></a>
        <a href="../en/" title="English"
          ><img
            src="/assets/united-kingdom.png"
            alt="English"
            width="20"
            height="20"
            class="language-flag" decoding="async"
        /></a>
        <a href="./" title="Français" aria-current="page"
          ><img
            src="/assets/france.png"
            alt="Français"
            width="20"
            height="20"
            class="language-flag is-active" decoding="async"
        /></a>
        <a href="../ru/" title="Русский"
          ><img
            src="/assets/russia.png"
            alt="Русский"
            width="20"
            height="20"
            class="language-flag" decoding="async"
        /></a>
        <a href="../es/" title="Español"
          ><img
            src="/assets/world.png"
            alt="Español"
            width="20"
            height="20"
            class="language-flag" decoding="async"
        /></a>
      </nav>
    </div>

    <!-- LOGO + SITE NAV -->
    <nav
      aria-label="Navigation principale"
      class="container mx-auto px-6 pt-6 pb-3 flex flex-col items-center gap-2"
    >
      <div class="site-header__brand-row">
      <a href="#hero" class="nav-brand" aria-label="Ethyria. Retour en haut">
        <img
          src="/assets/Logo_web.png"
          alt="Ethyria. Application d'interprétation des rêves avec IA pour Android"
          width="480"
          height="115"
          class="nav-brand-logo" decoding="async"
        />
      </a>
      <button class="nav-hamburger" id="navHamburger" type="button"
        aria-expanded="false" aria-controls="navMobilePanel"
        aria-label="Ouvrir le menu">
        <span class="nav-hamburger__bar"></span>
        <span class="nav-hamburger__bar"></span>
        <span class="nav-hamburger__bar"></span>
      </button>
    </div>
      <ul class="site-nav__links" role="list">
        <li><a href="#app-screens" class="site-nav__link">L'App</a></li>
        <li><a href="#pricing" class="site-nav__link">Tarifs</a></li>
        <li><a href="#traum-hub" class="site-nav__link">Rêves Hub</a></li>
        <li><a href="#faq" class="site-nav__link">FAQ</a></li>
        <li><a href="/assets/Ethyria_v1.0_def.apk" download class="site-nav__cta glow-button download-btn">Commencer gratuitement</a></li>
      </ul>
    </nav>
    <div class="nav-mobile-panel" id="navMobilePanel" aria-hidden="true">
      <div class="nav-mobile-card">
      <div class="nav-mobile-header">
        <a href="#"><img src="/assets/Logo_web.png" alt="Ethyria" width="160" height="38" class="nav-mobile-logo-img" decoding="async" /></a>
      </div>
      <ul class="nav-mobile-links" role="list">
        <li><a href="#app-screens" class="nav-mobile-link">APP</a></li>
        <li><a href="#features" class="nav-mobile-link">ANALYSE</a></li>
        <li><a href="#traumsymbole" class="nav-mobile-link">LEXIQUE</a></li>
        <li><a href="#vision" class="nav-mobile-link">VISION</a></li>
        <li><a href="#insight-pfad" class="nav-mobile-link">EXEMPLE</a></li>
        <li><a href="#live-analyse" class="nav-mobile-link nav-mobile-link--live">LIVE ANALYSE</a></li>
        <li><a href="#science" class="nav-mobile-link">USP</a></li>
        <li><a href="#pricing" class="nav-mobile-link">PRIX</a></li>
        <li><a href="#traum-hub" class="nav-mobile-link">RÊVES HUB</a></li>
        <li><a href="#faq" class="nav-mobile-link">FAQ</a></li>
        <li>
          <a href="/assets/Ethyria_v1.0_def.apk" download
            class="nav-mobile-link nav-mobile-link--cta download-btn"
            aria-label="Télécharger l'APK Ethyria pour Android">TÉLÉCHARGER</a>
        </li>
      </ul>
      </div>
    </div>

    </header><!-- /site-header -->

    <main id="main-content">
      <!-- ============================================================
           HERO. CTA ABOVE THE FOLD (C1 fix)
           ============================================================ -->
      <section
        id="hero"
        class="container mx-auto px-6 pt-10 pb-0 text-center relative z-10"
      >
        <div class="hero-glow" aria-hidden="true"></div>
        <div class="max-w-2xl mx-auto text-center" data-reveal="stagger">
        <div
          class="inline-block px-4 py-1 border border-cyan-500/30 rounded-full text-[10px] tracking-[0.3em] uppercase mb-5 ethyria-gradient-text text-center"
          data-reveal="hero"
          style="position: relative; z-index: 1"
        >
          ESSAI GRATUIT · ANDROID
        </div>
        <h1
          class="font-bold mb-4 leading-[1.1] text-center"
          data-reveal="hero"
          style="position: relative; z-index: 1; font-size: clamp(4rem, 16vw, 6rem); text-wrap: balance"
        ><span class="sr-only">Ethyria. Application d'interprétation des rêves par IA pour Android. </span>Les rêves ne mentent pas.</h1>
        <h2 class="hero-subtitle-seo mb-3" data-reveal="hero" style="font-size: clamp(1rem, 3vw, 1.35rem)">Interprétation des rêves par intelligence artificielle avec une profondeur qu'aucune autre application n'atteint</h2>
        <div class="flex items-center justify-center gap-3 mt-4 mb-4" data-reveal="hero" style="position: relative; z-index: 1">
          <div class="flex gap-0.5 text-amber-400 text-lg" aria-hidden="true">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <span class="text-sm text-gray-300"><strong class="text-white">4.8</strong> · 127 avis</span>
        </div>
        <div data-reveal="hero" class="mt-4" style="position: relative; z-index: 1">
          <div class="download-cta-block flex flex-col items-center gap-5">
            <a
              href="/assets/Ethyria_v1.0_def.apk"
              download
              class="glow-button download-btn text-base px-8 py-4"
              id="hero-download-btn"
              aria-label="Télécharger Ethyria gratuitement"
            >Commencer gratuitement</a>
            <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-gray-400">
              <span style="white-space:nowrap" class="flex items-center gap-1.5"><svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd"/></svg>Conforme RGPD</span>
              <span style="white-space:nowrap" class="flex items-center gap-1.5"><svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd"/></svg>Chiffrement local</span>
              <span style="white-space:nowrap" class="flex items-center gap-1.5"><svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838l-2.727 1.17 1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0z"/></svg>Serveurs EU</span>
            </div>
          </div>
        </div>
        </div><!-- /text block -->
      </section>

      <!-- Section Divider -->
      <div id="app-screens" class="section-divider" aria-hidden="true"></div>

      <!-- ============================================================
           APP SCREENSHOTS
           ============================================================ -->
      <section
        class="container mx-auto px-6 section-shell relative z-10"
      >
        <!-- 7-Grid: Sektion vollbreit (col-7) -->
        <div class="grid-7">
        <div class="col-7">
        <div class="text-center mb-16 reveal">
          <div class="section-pill section-pill--app ethyria-gradient-text">
            L'APPLICATION
          </div>
          <h2
            class="text-5xl sm:text-6xl md:text-6xl font-bold mb-4 leading-[1.15]"
          >
            Découvre <span class="ethyria-gradient-text">Ethyria</span>.<br />Ton Interprétation des Rêves.
          </h2>
          <p
            class="text-gray-300 max-w-2xl mx-auto text-base md:text-lg font-normal leading-relaxed"
          >
            Trois vrais écrans. Interprétation des rêves. Communauté. Statistiques.
          </p>
        </div>
        <div
          class="ethyria-slider reveal"
          data-slider="app-screens"
          data-autoplay="7000"
          role="region"
          aria-roledescription="Carrousel"
          aria-label="Captures d'écran de l'application"
        >
          <div class="ethyria-slider__controls ethyria-slider__controls--top">
            <button
              class="ethyria-slider__nav ethyria-slider__nav--prev"
              aria-label="Écran précédent"
              disabled
            >
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M14 6L8 12L14 18"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                />
              </svg>
            </button>
            <div class="ethyria-slider__dots" role="tablist"></div>
            <button
              class="ethyria-slider__nav ethyria-slider__nav--next"
              aria-label="Écran suivant"
            >
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M10 6L16 12L10 18"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                />
              </svg>
            </button>
          </div>
          <div class="ethyria-slider__track">
            <article class="ethyria-slider__slide app-showcase-item is-active">
              <div class="app-showcase-copy">
                <h3 class="text-2xl sm:text-3xl font-bold">Interprétation des rêves</h3>
                <p class="text-gray-300 leading-relaxed">
                  Cinq perspectives sur ton rêve. Freud. Jung. Spirituel. Biosynchrone. Général. Tu décides comment lire ton rêve.
                </p>
              </div>
              <div class="app-showcase-visual">
                <picture>
                  <source srcset="/assets/screenshots_new_1/analyse_fr.avif 1x, /assets/screenshots_new_1/analyse_fr@2x.avif 2x" type="image/avif" />
                  <source srcset="/assets/screenshots_new_1/analyse_fr.lossless.webp 1x, /assets/screenshots_new_1/analyse_fr@2x.lossless.webp 2x" type="image/webp" />
                  <img
                    src="/assets/screenshots_new_1/analyse_fr.jpg"
                  alt="Application Ethyria d'interprétation des rêves. Analyse IA selon Freud et Jung"
                  loading="eager"
                  fetchpriority="high"
                  width="460"
                  height="920"
                  class="app-showcase-image" decoding="async"
                />
                </picture>
              </div>
            </article>
            <article class="ethyria-slider__slide app-showcase-item">
              <div class="app-showcase-copy">
                <h3 class="text-2xl sm:text-3xl font-bold">Éther</h3>
                <p class="text-gray-300 leading-relaxed">
                  Vois ce que d'autres utilisateurs ont rêvé cette nuit. Thèmes oniriques partagés. Schémas mondiaux. Une communauté en construction. Chaque rêve que tu partages en fait partie.
                </p>
              </div>
              <div class="app-showcase-visual">
                <picture>
                  <source srcset="/assets/screenshots_new_1/aether_fr.avif 1x, /assets/screenshots_new_1/aether_fr@2x.avif 2x" type="image/avif" />
                  <source srcset="/assets/screenshots_new_1/aether_fr.lossless.webp 1x, /assets/screenshots_new_1/aether_fr@2x.lossless.webp 2x" type="image/webp" />
                  <img
                    src="/assets/screenshots_new_1/aether_fr.jpg"
                  alt="Ethyria Éther. Communauté mondiale des rêves et tendances partagées"
                  loading="lazy"
                  width="460"
                  height="920"
                  class="app-showcase-image" decoding="async"
                />
                </picture>
              </div>
            </article>
            <article class="ethyria-slider__slide app-showcase-item">
              <div class="app-showcase-copy">
                <h3 class="text-2xl sm:text-3xl font-bold">Statistiques</h3>
                <p class="text-gray-300 leading-relaxed">
                  Quels symboles reviennent sans cesse ? Quelles émotions t'accompagnent chaque nuit ? Ici, tu reconnais ce qui se répète dans tes rêves.
                </p>
              </div>
              <div class="app-showcase-visual">
                <picture>
                  <source srcset="/assets/screenshots_new_1/statistic_fr.avif 1x, /assets/screenshots_new_1/statistic_fr@2x.avif 2x" type="image/avif" />
                  <source srcset="/assets/screenshots_new_1/statistic_fr.lossless.webp 1x, /assets/screenshots_new_1/statistic_fr@2x.lossless.webp 2x" type="image/webp" />
                  <img
                    src="/assets/screenshots_new_1/statistic_fr.jpg"
                  alt="Ethyria Statistiques. Analyse des schémas de sommeil et du journal de rêves"
                  loading="lazy"
                  width="460"
                  height="920"
                  class="app-showcase-image" decoding="async"
                />
                </picture>
              </div>
            </article>
          </div>
          <div class="ethyria-slider__controls">
            <button
              class="ethyria-slider__nav ethyria-slider__nav--prev"
              aria-label="Écran précédent"
              disabled
            >
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M14 6L8 12L14 18"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                />
              </svg>
            </button>
            <div class="ethyria-slider__dots" role="tablist"></div>
            <button
              class="ethyria-slider__nav ethyria-slider__nav--next"
              aria-label="Écran suivant"
            >
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M10 6L16 12L10 18"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                />
              </svg>
            </button>
          </div>
        </div>
      
        </div><!-- /col-7 -->
        </div><!-- /grid-7 -->
        </section>

      <!-- Section Divider -->
      <div id="features" class="section-divider" aria-hidden="true"></div>

            <!-- ============================================================
           5 ANALYSE-PERSPEKTIVEN
           ============================================================ -->
      <section  class="section-shell relative z-10">
        <div class="container mx-auto px-6">
          <!-- 7-Grid: Sektion vollbreit (col-7) -->
          <div class="grid-7">
          <div class="col-7">
          <div class="text-center mb-16 reveal">
            <div
              class="section-pill section-pill--analysis ethyria-gradient-text"
            >
              Niveaux d'Analyse
            </div>
            <h2
              class="text-5xl sm:text-6xl md:text-6xl font-bold mb-4 leading-[1.15]"
            >
              5 <span class="ethyria-gradient-text">Perspectives</span><br />d'Interprétation des Rêves
            </h2>
            <p class="text-gray-300 max-w-2xl mx-auto text-base font-normal">
              Aucun rêve n'a qu'une seule vérité. Ethyria te montre cinq angles complètement différents sur le même rêve. Tu décides quelle perspective te touche.
            </p>
          </div>
          <div
            class="ethyria-slider reveal"
            data-slider="features"
            data-autoplay="5000"
            role="region"
            aria-roledescription="Carrousel"
            aria-label="Perspectives d'Analyse"
          >
          <div class="ethyria-slider__controls ethyria-slider__controls--top">
            <button
              class="ethyria-slider__nav ethyria-slider__nav--prev"
              aria-label="Perspective précédente"
              disabled
            >
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M14 6L8 12L14 18"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                />
              </svg>
            </button>
            <div class="ethyria-slider__dots" role="tablist"></div>
            <button
              class="ethyria-slider__nav ethyria-slider__nav--next"
              aria-label="Perspective suivante"
            >
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M10 6L16 12L10 18"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                />
              </svg>
            </button>
          </div>
            <div class="ethyria-slider__track">
              <div class="ethyria-slider__slide is-active">
                <div
                  class="glass-card feature-card flex flex-col gap-4 group hover:border-cyan-500/30 hover:shadow-[0_0_30px_rgba(1,191,255,0.08)] transition-all duration-300 max-w-lg mx-auto"
                >
                  <div
                    class="w-11 h-11 bg-cyan-500/15 rounded-xl flex items-center justify-center text-xl group-hover:bg-cyan-500/25 transition"
                  >
                    <i class=" ph-duotone ph-magnifying-glass" aria-hidden="true"></i>
                  </div>
                  <div>
                    <div
                      class="text-[10px] text-cyan-400 uppercase tracking-[0.2em] mb-1 font-normal"
                    >
                      General
                    </div>
                    <h4 class="font-bold text-base mb-2">Interprétation Générale</h4>
                    <p class="text-xs text-gray-300 leading-relaxed">
                      Pas de cadre. Pas de dogme. Ton rêve, lu tel qu'il est. Symboles. Émotions. Toute l'histoire.
                    </p>
                  </div>
                  <div
                    class="mt-auto pt-2 border-t border-white/5 text-[10px] text-cyan-400 uppercase tracking-widest"
                    style="color: #01bfff"
                  >
                    Point d'Entrée
                  </div>
                </div>
              </div>
              <div class="ethyria-slider__slide">
                <div
                  class="glass-card feature-card flex flex-col gap-4 group hover:border-purple-500/30 hover:shadow-[0_0_30px_rgba(84,88,251,0.08)] transition-all duration-300 max-w-lg mx-auto"
