---
import BaseLayout from '@/layouts/BaseLayout.astro';
const _body = `<div id="hero" class="anchor-top" aria-hidden="true"></div>
    <a href="#main-content" class="skip-link">Zum Hauptinhalt springen</a>

    <div class="bg-blob top-[-10%] left-[-10%]"></div>
    <div class="bg-blob bottom-[20%] right-[-5%]"></div>

    <!-- ============================================================
         SITE HEADER (sticky)
         ============================================================ -->
    <header role="banner" id="site-header" class="site-header">

    <!-- LANGUAGE BAR -->
    <div
      id="top"
      class="w-full flex justify-center px-6 pt-0 pb-1 relative z-20"
    >
      <nav class="language-switcher" aria-label="Sprachauswahl">
        <a href="/" title="Deutsch" aria-current="page"
          ><img
            src="/assets/german.png"
            alt="Deutsch"
            width="20"
            height="20"
            class="language-flag is-active" decoding="async"
        /></a>
        <a href="en/" title="English"
          ><img
            src="/assets/united-kingdom.png"
            alt="English"
            width="20"
            height="20"
            class="language-flag" decoding="async"
        /></a>
        <a href="fr/" title="Français"
          ><img
            src="/assets/france.png"
            alt="Français"
            width="20"
            height="20"
            class="language-flag" decoding="async"
        /></a>
        <a href="ru/" title="Русский"
          ><img
            src="/assets/russia.png"
            alt="Русский"
            width="20"
            height="20"
            class="language-flag" decoding="async"
        /></a>
        <a href="es/" title="Español"
          ><img
            src="/assets/world.png"
            alt="Español"
            width="20"
            height="20"
            class="language-flag" decoding="async"
        /></a>
      </nav>
    </div>

    <!-- LOGO + SITE NAV -->
    <nav
      aria-label="Hauptnavigation"
      class="container mx-auto px-6 pt-6 pb-3 flex flex-col items-center gap-2"
    >
      <div class="site-header__brand-row">
      <a href="#hero" class="nav-brand" aria-label="Ethyria. Zur Startseite">
        <img
          src="/assets/Logo_web.png"
          alt="Ethyria. Traumdeutung App mit KI für Android"
          width="480"
          height="115"
          class="nav-brand-logo" decoding="async"
        />
      </a>
      <button class="nav-hamburger" id="navHamburger" type="button"
        aria-expanded="false" aria-controls="navMobilePanel"
        aria-label="Menü öffnen">
        <span class="nav-hamburger__bar"></span>
        <span class="nav-hamburger__bar"></span>
        <span class="nav-hamburger__bar"></span>
      </button>
    </div>
      <ul class="site-nav__links" role="list">
        <li><a href="#app-screens" class="site-nav__link">Die App</a></li>
        <li><a href="#pricing" class="site-nav__link">Preise</a></li>
        <li><a href="#traum-hub" class="site-nav__link">Traum Hub</a></li>
        <li><a href="#faq" class="site-nav__link">FAQ</a></li>
        <li><a href="/assets/Ethyria_v1.0_def.apk" download class="site-nav__cta glow-button download-btn">Kostenlos starten</a></li>
      </ul>
    </nav>
    <div class="nav-mobile-panel" id="navMobilePanel" aria-hidden="true">
      <div class="nav-mobile-card">
      <div class="nav-mobile-header">
        <a href="#"><img src="/assets/Logo_web.png" alt="Ethyria" width="160" height="38" class="nav-mobile-logo-img" decoding="async" /></a>
      </div>
      <ul class="nav-mobile-links" role="list">
        <li><a href="#app-screens" class="nav-mobile-link">APP</a></li>
        <li><a href="#features" class="nav-mobile-link">ANALYSE</a></li>
        <li><a href="#traumsymbole" class="nav-mobile-link">LEXIKON</a></li>
        <li><a href="#vision" class="nav-mobile-link">VISION</a></li>
        <li><a href="#insight-pfad" class="nav-mobile-link">BEISPIEL</a></li>
        <li><a href="#live-analyse" class="nav-mobile-link nav-mobile-link--live">LIVE-ANALYSE</a></li>
        <li><a href="#science" class="nav-mobile-link">USP</a></li>
        <li><a href="#pricing" class="nav-mobile-link">PREISE</a></li>
        <li><a href="#traum-hub" class="nav-mobile-link">TRAUM HUB</a></li>
        <li><a href="#faq" class="nav-mobile-link">FAQ</a></li>
        <li>
          <a href="/assets/Ethyria_v1.0_def.apk" download
            class="nav-mobile-link nav-mobile-link--cta download-btn"
            aria-label="Ethyria APK fuer Android herunterladen">DOWNLOAD</a>
        </li>
      </ul>
      </div>
    </div>

    </header><!-- /site-header -->

    <main id="main-content">
      <!-- ============================================================
           HERO. CTA ABOVE THE FOLD (C1 fix)
           ============================================================ -->
      <section
        id="hero"
        class="container mx-auto px-6 pt-10 pb-0 text-center relative z-10"
      >
        <!-- Subtle glow -->
        <div class="hero-glow" aria-hidden="true"></div>

        <div class="max-w-2xl mx-auto text-center" data-reveal="stagger">
        <div
          class="inline-block px-4 py-1 border border-cyan-500/30 rounded-full text-[10px] tracking-[0.3em] uppercase mb-5 ethyria-gradient-text text-center"
          data-reveal="hero"
          style="position: relative; z-index: 1"
        >
          KOSTLOS STARTEN · ANDROID
        </div>
        <h1
          class="font-bold mb-4 leading-[1.1] text-center"
          data-reveal="hero"
          style="position: relative; z-index: 1; font-size: clamp(4rem, 16vw, 6rem); text-wrap: balance"
        ><span class="sr-only">Ethyria. Traumdeutung App mit KI für Android. </span>Träume lügen nicht.</h1>
        <h2 class="hero-subtitle-seo mb-3" data-reveal="hero" style="font-size: clamp(1rem, 3vw, 1.35rem)">KI-gestützte Traumdeutung in Tiefe und Präzision, die keine andere App erreicht</h2>

        <!-- App-Store-Rating -->
        <div class="flex items-center justify-center gap-3 mt-4 mb-4" data-reveal="hero" style="position: relative; z-index: 1">
          <div class="flex gap-0.5 text-amber-400 text-lg" aria-hidden="true">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <span class="text-sm text-gray-300"><strong class="text-white">4.8</strong> · 127 Bewertungen</span>
        </div>

        <!-- Hero CTA. Above the fold -->
        <div data-reveal="hero" class="mt-4" style="position: relative; z-index: 1">
          <div class="download-cta-block flex flex-col items-center gap-5">
            <a
              href="/assets/Ethyria_v1.0_def.apk"
              download
              class="glow-button download-btn text-base px-8 py-4"
              id="hero-download-btn"
              aria-label="Ethyria kostenlos herunterladen"
            >Kostenlos starten</a>
            <!-- Trust-Badges -->
            <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-gray-400">
              <span class="flex items-center gap-1.5" style="white-space:nowrap"><svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd"/></svg>DSGVO-konform</span>
              <span class="flex items-center gap-1.5" style="white-space:nowrap"><svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd"/></svg>Lokal verschlüsselt</span>
            </div>
          </div>
        </div>
        </div><!-- /text block -->
      </section>

      <!-- Section Divider -->
      <div id="app-screens" class="section-divider" aria-hidden="true"></div>

      <!-- ============================================================
           APP SCREENSHOTS
           ============================================================ -->
      <section
        class="container mx-auto px-6 section-shell relative z-10"
      >
        <!-- 7-Grid: Header + Slider-Galerie vollbreit (col-7) -->
        <div class="grid-7">
        <div class="col-7">
        <div class="text-center mb-16" data-reveal>
          <div class="section-pill section-pill--app ethyria-gradient-text">
            DIE APP
          </div>
          <h2
            class="text-5xl sm:text-6xl md:text-6xl font-bold mb-4 leading-[1.15]"
          >
            Erlebe <span class="ethyria-gradient-text">Ethyria</span>.<br />Deine Traumdeutung.
          </h2>
          <p
            class="text-gray-300 max-w-2xl mx-auto text-base md:text-lg font-normal leading-relaxed"
          >
            Drei echte Screens. Traumdeutung. Community. Statistiken.
          </p>
        </div>
        <div
          class="ethyria-slider" data-reveal
          data-slider="app-screens"
          data-autoplay="7000"
          role="region"
          aria-roledescription="Karussell"
          aria-label="App Screenshots"
        >
          <div class="ethyria-slider__controls ethyria-slider__controls--top">
            <button
              class="ethyria-slider__nav ethyria-slider__nav--prev"
              aria-label="Vorheriger Screen"
              disabled
            >
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M14 6L8 12L14 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
              </svg>
            </button>
            <div class="ethyria-slider__dots" role="tablist"></div>
            <button class="ethyria-slider__nav ethyria-slider__nav--next" aria-label="Nächster Screen">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M10 6L16 12L10 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
              </svg>
            </button>
          </div>
          <div class="ethyria-slider__track">
            <article class="ethyria-slider__slide app-showcase-item is-active">
              <div class="app-showcase-copy">
                <h3 class="text-2xl sm:text-3xl font-bold">Traumdeutung</h3>
                <p class="text-gray-300 leading-relaxed">
                  Fünf Perspektiven auf deinen Traum. Freud. Jung. Spirituell.
                  Biosynchron. Allgemein. Du entscheidest, wie du deinen Traum
                  liest.
                </p>
              </div>
              <div class="app-showcase-visual">
                <picture>
                  <source srcset="/assets/screenshots_new_1/analyse_de.avif 1x, /assets/screenshots_new_1/analyse_de@2x.avif 2x" type="image/avif" />
                  <source srcset="/assets/screenshots_new_1/analyse_de.lossless.webp 1x, /assets/screenshots_new_1/analyse_de@2x.lossless.webp 2x" type="image/webp" />
                  <img src="/assets/screenshots_new_1/analyse_de.jpg" alt="Screenshot der Ethyria Traumdeutung App: KI-Analyseergebnis zeigt psychologische Traumdeutung nach Freud und Jung mit Symbolen, emotionaler Kurve und Handlungsimpuls" loading="eager" fetchpriority="high" width="460" height="920" class="app-showcase-image" decoding="async" />
                </picture>
              </div>
            </article>
            <article class="ethyria-slider__slide app-showcase-item">
              <div class="app-showcase-copy">
                <h3 class="text-2xl sm:text-3xl font-bold">Äther</h3>
                <p class="text-gray-300 leading-relaxed">
                  Sieh, was andere Nutzer heute Nacht geträumt haben. Geteilte
                  Traumthemen. Globale Muster. Eine Community im Aufbau.
                  Jeder Traum, den du teilst, gehört dazu.
                </p>
              </div>
              <div class="app-showcase-visual">
                <picture>
                  <source srcset="/assets/screenshots_new_1/aether_de.avif 1x, /assets/screenshots_new_1/aether_de@2x.avif 2x" type="image/avif" />
                  <source srcset="/assets/screenshots_new_1/aether_de.lossless.webp 1x, /assets/screenshots_new_1/aether_de@2x.lossless.webp 2x" type="image/webp" />
                  <img src="/assets/screenshots_new_1/aether_de.jpg" alt="Screenshot der Ethyria App Äther-Feature: KI-generierte Traumbilder aus der Community mit emotionalen Farbsignaturen und geteilten Traumtrends" loading="lazy" width="460" height="920" class="app-showcase-image" decoding="async" />
                </picture>
              </div>
            </article>
            <article class="ethyria-slider__slide app-showcase-item">
              <div class="app-showcase-copy">
                <h3 class="text-2xl sm:text-3xl font-bold">Statistiken</h3>
                <p class="text-gray-300 leading-relaxed">
                  Welche Symbole kehren immer wieder? Welche Emotionen
                  begleiten dich jede Nacht? Hier erkennst du, was sich in
                  deinen Träumen wiederholt.
                </p>
              </div>
              <div class="app-showcase-visual">
                <picture>
                  <source srcset="/assets/screenshots_new_1/statistic_de.avif 1x, /assets/screenshots_new_1/statistic_de@2x.avif 2x" type="image/avif" />
                  <source srcset="/assets/screenshots_new_1/statistic_de.lossless.webp 1x, /assets/screenshots_new_1/statistic_de@2x.lossless.webp 2x" type="image/webp" />
                  <img src="/assets/screenshots_new_1/statistic_de.jpg" alt="Screenshot der Ethyria App Statistik-Ansicht: monatliches Traumtagebuch mit Schlafmuster-Tracking, häufigsten Traumsymbolen und emotionalen Verlaufstrends" loading="lazy" width="460" height="920" class="app-showcase-image" decoding="async" />
                </picture>
              </div>
            </article>
          </div>
          <div class="ethyria-slider__controls">
            <button class="ethyria-slider__nav ethyria-slider__nav--prev" aria-label="Vorheriger Screen" disabled>
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M14 6L8 12L14 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
              </svg>
            </button>
            <div class="ethyria-slider__dots" role="tablist"></div>
            <button class="ethyria-slider__nav ethyria-slider__nav--next" aria-label="Nächster Screen">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M10 6L16 12L10 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
              </svg>
            </button>
          </div>
        </div>
        </div><!-- /col-7 -->
        </div><!-- /grid-7 -->
      </section>

      <!-- Section Divider -->
      <div id="features" class="section-divider" aria-hidden="true"></div>

      <!-- ============================================================
           5 ANALYSE-PERSPEKTIVEN
           ============================================================ -->
      <section  class="section-shell relative z-10">
        <div class="container mx-auto px-6">
          <!-- 7-Grid: Analyse-Perspektiven, Galerie vollbreit (col-7) -->
          <div class="grid-7">
          <div class="col-7">
          <div class="text-center mb-16" data-reveal>
            <div
              class="section-pill section-pill--analysis ethyria-gradient-text"
            >
              Analyse Ebenen
            </div>
            <h2
              class="text-5xl sm:text-6xl md:text-6xl font-bold mb-4 leading-[1.15]"
            >
              5 <span class="ethyria-gradient-text">Perspektiven</span><br />der Traumdeutung
            </h2>
            <p class="text-gray-300 max-w-2xl mx-auto text-base font-normal">
              Kein Traum hat nur eine Wahrheit. Ethyria zeigt dir fünf völlig
              verschiedene Blickwinkel auf denselben Traum. Du entscheidest,
              welche Perspektive dich trifft.
            </p>
          </div>
          <div
            class="ethyria-slider" data-reveal
            data-slider="features"
            data-autoplay="5000"
            role="region"
            aria-roledescription="Karussell"
            aria-label="Analyse Perspektiven"
          >
            <div class="ethyria-slider__controls ethyria-slider__controls--top">
              <button
                class="ethyria-slider__nav ethyria-slider__nav--prev"
                aria-label="Vorherige Perspektive"
                disabled
              >
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M14 6L8 12L14 18"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    fill="none"
                  />
                </svg>
              </button>
              <div class="ethyria-slider__dots" role="tablist"></div>
              <button
                class="ethyria-slider__nav ethyria-slider__nav--next"
                aria-label="Nächste Perspektive"
              >
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M10 6L16 12L10 18"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    fill="none"
                  />
                </svg>
              </button>
            </div>
            <div class="ethyria-slider__track">
              <!-- General -->
              <div class="ethyria-slider__slide is-active">
                <div
                  class="glass-card feature-card flex flex-col gap-4 group hover:border-cyan-500/30 hover:shadow-[0_0_30px_rgba(1,191,255,0.08)] transition-all duration-300 max-w-lg mx-auto"
                >
                  <div
                    class="w-11 h-11 bg-cyan-500/15 rounded-xl flex items-center justify-center text-xl group-hover:bg-cyan-500/25 transition"
                  >
                    <i class=" ph-duotone ph-magnifying-glass" aria-hidden="true"></i>
                  </div>
                  <div>
                    <div
                      class="text-[10px] text-cyan-400 uppercase tracking-[0.2em] mb-1 font-normal"
                    >
                      General
                    </div>
                    <h4 class="font-bold text-base mb-2">Allgemeine Deutung</h4>
                    <p class="text-xs text-gray-300 leading-relaxed">
                      Kein Framework. Kein Dogma. Dein Traum, gelesen wie er
                      ist. Symbole. Emotionen. Die ganze Geschichte.
                    </p>
                  </div>
                  <div
                    class="mt-auto pt-2 border-t border-white/5 text-[10px] text-cyan-400 uppercase tracking-widest"
                    style="color: #01bfff"
                  >
                    Einstieg
                  </div>
                </div>
              </div>
              <!-- Freud -->
              <div class="ethyria-slider__slide">
                <div
                  class="glass-card feature-card flex flex-col gap-4 group hover:border-purple-500/30 hover:shadow-[0_0_30px_rgba(84,88,251,0.08)] transition-all duration-300 max-w-lg mx-auto"
                >
                  <div
                    class="w-11 h-11 bg-purple-500/15 rounded-xl flex items-center justify-center text-xl group-hover:bg-purple-500/25 transition"
                  >
                    <i class=" ph-duotone ph-brain" aria-hidden="true"></i>
                  </div>
                  <div>
                    <div
                      class="text-[10px] text-purple-400 uppercase tracking-[0.2em] mb-1 font-normal"
                    >
                      Freud
                    </div>
                    <h4 class="font-bold text-base mb-2">
                      Klassische Psychoanalyse
                    </h4>
                    <p class="text-xs text-gray-300 leading-relaxed">
                      Was willst du wirklich? Und warum traust du dich nicht,
                      es auszusprechen? Freud schaut genau dahin, wo du
                      wegguckst.
                    </p>
                  </div>
                  <div
                    class="mt-auto pt-2 border-t border-white/5 text-[10px] text-cyan-400 uppercase tracking-widest"
                    style="color: #01bfff"
                  >
                    Tiefenpsychologie
                  </div>
                </div>
              </div>
              <!-- Jung -->
