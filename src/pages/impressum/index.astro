---
import BaseLayout from '@/layouts/BaseLayout.astro';
const _body = `
    <div class="bg-blob top-[-10%] left-[-10%]"></div>

    <nav
      class="container mx-auto px-6 py-6 flex justify-center items-center relative z-10"
    >
      <a href="index.html" class="nav-brand">
        <img
          src="assets/Logo_web.png"
          alt="Ethyria zurück zur Startseite"
          width="240"
          height="57"
          class="nav-brand-logo"
          style="max-width: 240px" decoding="async"
        />
      </a>
    </nav>

    <main class="container mx-auto px-6 py-12 relative z-10 max-w-3xl">
      <!-- 7-Grid: Pillar-Prosa-Kolumne vollbreit (col-7) -->
      <div class="grid-7">
      <h1 class="text-4xl font-bold mb-10 ethyria-gradient-text">Impressum</h1>

      <section class="mb-10">
        <h2 class="text-xl font-bold mb-3 text-white">
          Angaben gemäß § 5 ECG (E-Commerce-Gesetz)
        </h2>
        <div class="text-gray-300 leading-relaxed space-y-1">
          <p>
            <strong class="text-white">Oliver Stolz</strong>
          </p>
          <p>Ethyria Dream Analysis</p>
          <p>Freistädter Str. 65</p>
          <p>4040 Linz, Österreich</p>
        </div>
      </section>

      <section class="mb-10">
        <h2 class="text-xl font-bold mb-3 text-white">Kontakt</h2>
        <div class="text-gray-300 leading-relaxed space-y-1">
          <p>
            E-Mail:
            <!--email_off--><a
              href="mailto:support@ethyria.at"
              data-copy-email="support@ethyria.at"
              title="E-Mail kopieren"
              class="text-cyan-400 hover:underline"
              >support@ethyria.at</a><!--/email_off-->
          </p>
          <p>
            Website:
            <a href="https://ethyria.at" class="text-cyan-400 hover:underline"
              >https://ethyria.at</a
            >
          </p>
        </div>
      </section>

      <section class="mb-10">
        <h2 class="text-xl font-bold mb-3 text-white">
          Unternehmensgegenstand
        </h2>
        <p class="text-gray-300 leading-relaxed">
          Entwicklung und Betrieb der Ethyria App Traumdeutung und
          Traumtagebuch-Anwendung für Android.
        </p>
      </section>

      <section class="mb-10">
        <h2 class="text-xl font-bold mb-3 text-white">Rechtliche Hinweise</h2>
        <p class="text-gray-300 leading-relaxed mb-3">
          Die Inhalte dieser Website wurden mit größtmöglicher Sorgfalt
          erstellt. Für die Richtigkeit, Vollständigkeit und Aktualität der
          Inhalte übernehmen wir keine Gewähr.
        </p>
        <p class="text-gray-300 leading-relaxed mb-3">
          <strong class="text-white">Haftungsausschluss Traumdeutung:</strong>
          Die von Ethyria bereitgestellten Traumdeutungen und -analysen dienen
          ausschließlich der Selbstreflexion und Unterhaltung. Sie ersetzen
          keine professionelle psychologische oder therapeutische Beratung.
        </p>
        <p class="text-gray-300 leading-relaxed">
          <strong class="text-white">Urheberrecht:</strong> Die durch den
          Seitenbetreiber erstellten Inhalte und Werke auf diesen Seiten
          unterliegen dem österreichischen Urheberrecht. Die Vervielfältigung,
          Bearbeitung, Verbreitung und jede Art der Verwertung außerhalb der
          Grenzen des Urheberrechtes bedürfen der schriftlichen Zustimmung des
          jeweiligen Autors.
        </p>
      </section>

      <section class="mb-10">
        <h2 class="text-xl font-bold mb-3 text-white">
          Online-Streitbeilegung
        </h2>
        <p class="text-gray-300 leading-relaxed">
          Die Europäische Kommission stellt eine Plattform zur
          Online-Streitbeilegung (OS) bereit:
          <a
            href="https://ec.europa.eu/consumers/odr"
            class="text-cyan-400 hover:underline"
            target="_blank"
            rel="noopener"
          >
            https://ec.europa.eu/consumers/odr
          </a>
        </p>
      </section>

      <div class="border-t border-white/10 pt-8 mt-8">
        <a href="index.html" class="text-cyan-400 hover:underline text-sm"
          >← Zurück zur Startseite</a
        >
        <span class="mx-4 text-white/20">|</span>
        <a href="datenschutz.html" class="text-cyan-400 hover:underline text-sm"
          >Datenschutzerklärung</a
        >
        <span class="mx-4 text-white/20">|</span>
        <a href="agb.html" class="text-cyan-400 hover:underline text-sm"
          >AGB</a
        >
      </div>
          </div><!-- /grid-7 -->
    </main>

    <footer class="border-t border-white/5 py-8 text-center mt-16">
      <div class="container mx-auto px-6">
        <p class="text-gray-600 text-xs">
          © Ethyria ·
          <a href="impressum.html" class="hover:text-cyan-400">Impressum</a> ·
          <a href="datenschutz.html" class="hover:text-cyan-400">Datenschutz</a> ·
          <a href="agb.html" class="hover:text-cyan-400">AGB</a>
        </p>
      </div>
    </footer>
    
  `;
---

<BaseLayout
  lang="de"
  title="Impressum | Ethyria"
  description=""
  keywords=""
  path="/impressum/"
>
  <Fragment set:html={_body} />
</BaseLayout>
