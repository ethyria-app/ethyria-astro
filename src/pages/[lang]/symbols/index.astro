---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SYMBOLS, HUB_STRINGS, TOP_SLUGS } from '@/data/symbolsHub';
import type { Locale } from '@/data/symbolsHub';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = langParam as Locale;
const s = HUB_STRINGS[lang];
const SITE = 'https://ethyria.at';
const symbolUrl = `${SITE}/${lang}/symbols/`;
const langPath = `/${lang}`;

const OG_IMAGES: Record<string, string> = {
  en: `${SITE}/assets/og-image-en.png`,
  fr: `${SITE}/assets/og-image-fr.png`,
  es: `${SITE}/assets/og-image-es.png`,
  ru: `${SITE}/assets/og-image-ru.png`,
};

const META: Record<string, { title: string; description: string; keywords: string }> = {
  en: {
    title: 'Dream Symbols A-Z | Ethyria AI Dream Analysis',
    description: 'All dream symbols at a glance: Falling, Teeth, Being Chased, Flying, Water, Death, Snakes and more. AI-powered dream interpretation based on Freud, Jung & spiritual perspectives.',
    keywords: 'dream symbols, dream symbol dictionary, dream interpretation A-Z, dream symbols meaning, dream interpretation guide',
  },
  fr: {
    title: 'Symboles de Rêves A-Z | Ethyria Analyse de Rêves IA',
    description: 'Tous les symboles de rêves en un coup d\'œil : Chute, Dents, Être poursuivi, Vol, Eau, Mort, Serpents et plus. Interprétation IA selon Freud, Jung & traditions spirituelles.',
    keywords: 'symboles de rêves, dictionnaire des symboles de rêves, interprétation des rêves A-Z, signification des symboles de rêves',
  },
  es: {
    title: 'Símbolos de Sueños A-Z | Ethyria Análisis de Sueños IA',
    description: 'Todos los símbolos de sueños de un vistazo: Caída, Dientes, Ser perseguido, Vuelo, Agua, Muerte, Serpientes y más. Interpretación con IA según Freud, Jung y perspectivas espirituales.',
    keywords: 'símbolos de sueños, diccionario de símbolos oníricos, interpretación de sueños A-Z, significado de símbolos de sueños',
  },
  ru: {
    title: 'Символы снов А-Я | Ethyria Анализ снов с ИИ',
    description: 'Все символы снов с первого взгляда: Падение, Зубы, Преследование, Полёт, Вода, Смерть, Змеи и многое другое. Интерпретация с ИИ по Фрейду, Юнгу и духовным традициям.',
    keywords: 'символы снов, словарь символов снов, толкование снов, значение символов снов',
  },
};

const meta = META[lang];

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  inLanguage: lang,
  name: s.h1,
  description: s.desc,
  url: symbolUrl,
  isPartOf: { '@type': 'WebSite', name: 'Ethyria', url: `${SITE}/` },
  publisher: { '@type': 'Organization', name: 'Ethyria', url: `${SITE}/`, logo: `${SITE}/assets/Ethyria_symbol.png` },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: SYMBOLS.length,
    itemListElement: SYMBOLS.map((sym, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: sym.labels[lang].name,
      url: `${SITE}/${lang}/symbols/${sym.slug}/`,
    })),
  },
};

const breadcrumbNames: Record<string, string> = { en: 'Dream Symbols', fr: 'Symboles de rêves', es: 'Símbolos de sueños', ru: 'Символы снов' };
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ethyria', item: `${SITE}/${lang}/` },
    { '@type': 'ListItem', position: 2, name: breadcrumbNames[lang], item: symbolUrl },
  ],
};

const topSymbols = TOP_SLUGS.map(slug => SYMBOLS.find(s => s.slug === slug)!);
const navTitles: Record<string, string> = { en: 'Dream Symbols', fr: 'Symboles de rêves', es: 'Símbolos de sueños', ru: 'Символы снов' };
const statsLabels: Record<string, { a: string; b: string; c: string }> = {
  en: { a: 'Symbols', b: 'Interpretation Models', c: 'Variations' },
  fr: { a: 'Symboles', b: 'Modèles d\'interprétation', c: 'Variantes' },
  es: { a: 'Símbolos', b: 'Modelos de interpretación', c: 'Variantes' },
  ru: { a: 'Символов', b: 'Моделей интерпретации', c: 'Вариантов' },
};
const ctaDescs: Record<string, string> = {
  en: 'Ethyria analyzes every dream individually. With AI using Freud, Jung, spiritual, Islamic and psychological perspectives.',
  fr: 'Ethyria analyse chaque rêve individuellement. Avec l\'IA selon Freud, Jung, la spiritualité, l\'islam et la psychologie.',
  es: 'Ethyria analiza cada sueño individualmente. Con IA según Freud, Jung, perspectivas espiritual, islámica y psicológica.',
  ru: 'Ethyria анализирует каждый сон индивидуально. С ИИ по Фрейду, Юнгу, духовным, исламским и психологическим перспективам.',
};
---

<BaseLayout
  {lang}
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  path={`/${lang}/symbols/`}
  ogType="website"
  ogImage={OG_IMAGES[lang]}
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Nav -->
  <nav
    class="sticky top-0 z-50 flex items-center px-6 py-3"
    style="backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);background:rgba(16,12,31,0.75);border-bottom:1px solid rgba(255,255,255,0.06)"
    aria-label="Navigation"
  >
    <a href={`/${lang}/#beta`} class="ethyria-slider__nav" aria-label={s.footerBack}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 6L8 12L14 18" />
      </svg>
    </a>
    <span class="flex-1 text-center text-sm font-semibold tracking-wider uppercase text-gray-300" style="font-family:Poppins,Arial,sans-serif">{navTitles[lang]}</span>
    <span class="w-7" aria-hidden="true"></span>
  </nav>

  <main class="mx-auto px-6" style="max-width:690px">
    <div class="grid-7">

      <!-- Hero -->
      <header class="text-center section-shell reveal">
        <div class="section-pill ethyria-gradient-text">{s.pill}</div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-4 leading-tight ethyria-gradient-text" style="font-family:Poppins,Arial,sans-serif">{s.h1}</h1>
        <p class="text-lg sm:text-xl text-gray-300 leading-relaxed max-w-3xl mx-auto mb-6">{s.desc}</p>
        <div class="flex flex-wrap justify-center gap-6 text-center">
          <div>
            <span class="block text-3xl font-bold text-white mb-1" style="font-family:Poppins,Arial,sans-serif">15</span>
            <span class="text-xs text-gray-400 uppercase tracking-wider">{statsLabels[lang].a}</span>
          </div>
          <div>
            <span class="block text-3xl font-bold text-white mb-1" style="font-family:Poppins,Arial,sans-serif">4</span>
            <span class="text-xs text-gray-400 uppercase tracking-wider">{statsLabels[lang].b}</span>
          </div>
          <div>
            <span class="block text-3xl font-bold text-white mb-1" style="font-family:Poppins,Arial,sans-serif">60+</span>
            <span class="text-xs text-gray-400 uppercase tracking-wider">{statsLabels[lang].c}</span>
          </div>
        </div>
      </header>

      <!-- Guide link -->
      <div class="text-center mb-8 reveal">
        <a href={s.guideHref} class="inline-flex items-center gap-2 text-sm text-purple-300 hover:text-purple-200 transition-colors" style="background:rgba(139,92,246,0.1);border:1px solid rgba(139,92,246,0.25);border-radius:2rem;padding:0.5rem 1.25rem">
          📖 <span>{s.guideLabel}</span> →
        </a>
      </div>

      <!-- Top searched -->
      <section class="mb-10 reveal">
        <h2 class="text-center text-sm font-semibold text-gray-500 uppercase tracking-widest mb-4" style="font-family:Poppins,Arial,sans-serif">{s.topLabel}</h2>
        <div class="flex flex-wrap justify-center gap-3">
          {topSymbols.map(sym => (
            <a
              href={`${langPath}/symbols/${sym.slug}/`}
              class="px-5 py-2.5 rounded-full text-sm font-semibold transition-all duration-300 hover:scale-105"
              style="background:rgba(1,191,255,0.12);border:1px solid rgba(1,191,255,0.3);color:#22d3ee;font-family:Poppins,Arial,sans-serif"
            >
              <img src={`/symbols/img/${sym.img}`} alt="" class="symbol-quicklink-img" aria-hidden="true" />
              {sym.labels[lang].name.split(' ')[0]}
            </a>
          ))}
        </div>
      </section>

      <!-- Filter -->
      <section class="mb-10 reveal">
        <h2 class="text-center text-sm font-semibold text-gray-500 uppercase tracking-widest mb-4" style="font-family:Poppins,Arial,sans-serif">{s.filterLabel}</h2>
        <div class="flex flex-wrap justify-center gap-3" id="emotion-filters">
          <button data-filter="all" class="filter-btn active px-4 py-2 rounded-full text-sm font-medium transition-all duration-200" style="font-family:Poppins,Arial,sans-serif">{s.filterAll}</button>
          <button data-filter="angst" class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200" style="font-family:Poppins,Arial,sans-serif">{s.filterAngst}</button>
          <button data-filter="kontrolle" class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200" style="font-family:Poppins,Arial,sans-serif">{s.filterKontrolle}</button>
          <button data-filter="beziehung" class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200" style="font-family:Poppins,Arial,sans-serif">{s.filterBeziehung}</button>
          <button data-filter="transformation" class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200" style="font-family:Poppins,Arial,sans-serif">{s.filterTransformation}</button>
        </div>
      </section>

      <!-- Symbol Grid -->
      <div class="grid-7 gap-6 mb-16 reveal" id="symbol-grid">
        {SYMBOLS.map(sym => (
          <a
            href={`${langPath}/symbols/${sym.slug}/`}
            data-category={sym.categories}
            class="col-7 col-t-3 col-d-3 symbol-card glass-card group flex flex-col p-6 rounded-2xl transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:shadow-cyan-500/10"
          >
            <img src={`/symbols/img/${sym.img}`} alt={sym.labels[lang].name} class="symbol-card-img" loading="lazy" />
            <h3 class="text-xl font-bold mb-2 text-cyan-300 group-hover:text-cyan-200" style="font-family:Poppins,Arial,sans-serif">{sym.labels[lang].name}</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-3">{sym.labels[lang].subtitle}</p>
            <span class="text-xs text-cyan-500/70 font-medium mt-auto">{s.cardSuffix}</span>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <section class="text-center mb-16 reveal">
        <div class="max-w-2xl mx-auto p-8 rounded-3xl" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08)">
          <h2 class="text-2xl sm:text-3xl font-bold mb-4 ethyria-gradient-text" style="font-family:Poppins,Arial,sans-serif">{s.ctaH2}</h2>
          <p class="text-gray-300 mb-6 max-w-lg mx-auto">{ctaDescs[lang]}</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/#beta`} class="inline-block px-8 py-4 font-bold text-white rounded-2xl text-lg transition-all duration-300 hover:scale-105" style="font-family:Poppins,Arial,sans-serif;background:linear-gradient(135deg,#01bfff 0%,#0066ff 100%);box-shadow:0 6px 24px rgba(1,191,255,0.3)">{s.ctaBtn1}</a>
            <a href={`/${lang}/#beta`} class="inline-block px-8 py-4 font-bold rounded-2xl text-lg transition-all duration-300 hover:scale-105" style="font-family:Poppins,Arial,sans-serif;border:1px solid rgba(1,191,255,0.4);color:#22d3ee">{s.ctaBtn2}</a>
          </div>
        </div>
      </section>

    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-white/5 py-8">
    <div class="mx-auto px-6" style="max-width:690px">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="text-center md:text-left">
          <p class="text-sm text-gray-400">{s.footerDesc}</p>
          <p class="text-xs text-gray-500 mt-1">{s.footerSub}</p>
        </div>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <a href={`/${lang}/#beta`} class="text-gray-400 hover:text-cyan-400 transition-colors">{s.footerBack}</a>
          <a href="https://ethyria.at" class="text-cyan-500 hover:underline">ethyria.at</a>
          <a href="mailto:support@ethyria.at" class="text-cyan-500 hover:underline">support@ethyria.at</a>
        </div>
      </div>
    </div>
  </footer>

  <script is:inline src="/assets/symbols-filter.js" defer></script>
  <style>
    .filter-btn { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #9ca3af; }
    .filter-btn:hover, .filter-btn.active { background: rgba(1,191,255,0.15); border-color: rgba(1,191,255,0.4); color: #22d3ee; }
  </style>
</BaseLayout>
